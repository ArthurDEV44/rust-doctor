{
  "name": "rust-doctor",
  "version": "0.1.8",
  "description": "A unified code health tool for Rust — scan, score, and fix your codebase",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArthurDEV44/rust-doctor"
  },
  "homepage": "https://github.com/ArthurDEV44/rust-doctor",
